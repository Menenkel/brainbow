# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/brainbow"

# Individual database connection parameters (alternative to DATABASE_URL)
PGHOST="localhost"
PGPORT="5432"
PGUSER="username"
PGPASSWORD="password"
PGDATABASE="brainbow"

# Groq API Configuration  
GROQ_API_KEY="gsk_your-groq-api-key-here"

# Node Environment
NODE_ENV="development"

# Google Calendar Integration (Optional)
# Place credentials.json file in project root instead of using environment variables
# The app will automatically detect and use the credentials file